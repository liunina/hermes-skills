{
  "id": "publish-markdown-to-wiki",
  "manifestType": "workflow-component",
  "name": "Publish Markdown to Wiki.js",
  "description": "Publish or update a Markdown page in Wiki.js through a reusable n8n component workflow. This is an implementation component used by business workflow skills, not a standalone agent skill.",
  "status": "active",
  "category": "publishing",
  "tags": ["wiki", "wikijs", "markdown", "publish", "component", "n8n"],
  "workflows": [
    {
      "role": "primary",
      "name": "[组件] Publish Markdown to Wiki.js",
      "id": "configure-in-private-n8n"
    },
    {
      "role": "wrapper",
      "name": "[MCP入口] Publish Markdown to Wiki.js webhook",
      "id": "configure-in-private-n8n"
    }
  ],
  "transport": {
    "type": "webhook",
    "urlEnv": "PUBLISH_MARKDOWN_TO_WIKI_WEBHOOK_URL",
    "secretFile": "secrets/publish-markdown-to-wiki.webhook-url.txt",
    "timeoutMs": 300000
  },
  "defaults": {
    "locale": "zh-CN",
    "mode": "upsert",
    "tags": []
  },
  "sideEffectMode": "always",
  "sideEffectFields": ["mode"],
  "safeSmokeInput": {},
  "expectedSmokeError": "side_effect_confirmation_required",
  "outputFields": [
    "ok",
    "httpStatus",
    "wikiLink",
    "pageId",
    "path",
    "title",
    "status",
    "message"
  ]
}
